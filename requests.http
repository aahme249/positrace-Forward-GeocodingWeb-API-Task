### Dash-prefixed unit
POST http://localhost:8080/api/v1/geocode
Content-Type: application/json

{
  "addresses": [
    "123-12 Main St, Toronto, ON M5V 2T6"
  ]
}

### Apt / Apt.
POST http://localhost:8080/api/v1/geocode
Content-Type: application/json

{
  "addresses": [
    "Apt 4 456 Yonge St, Toronto, ON M4Y 1X9",
    "Apt. 12B 789 Bloor St W, Toronto, ON M6G 1L5"
  ]
}

### Unit
POST http://localhost:8080/api/v1/geocode
Content-Type: application/json

{
  "addresses": [
    "Unit 201 789 Queen St W, Toronto, ON M6J 1G1"
  ]
}

### Suite
POST http://localhost:8080/api/v1/geocode
Content-Type: application/json

{
  "addresses": [
    "Suite 300 1000 De La Gauchetière W, Montreal, QC H3B 4W5"
  ]
}

### Hash (#)
POST http://localhost:8080/api/v1/geocode
Content-Type: application/json

{
  "addresses": [
    "#5 100 Wellington St, Ottawa, ON K1A 0A9"
  ]
}

### Postal code fallback (fake street, real postal code)
POST http://localhost:8080/api/v1/geocode
Content-Type: application/json

{
  "addresses": [
    "99999 Nowhere Blvd, Apt 12, Toronto, ON M5V 3A8"
  ]
}

### Not found (no valid address or postal code)
POST http://localhost:8080/api/v1/geocode
Content-Type: application/json

{
  "addresses": [
    "Unit 5 99999 Nowhere Blvd, Faketown, ON"
  ]
}

### Mixed batch
POST http://localhost:8080/api/v1/geocode
Content-Type: application/json

{
  "addresses": [
    "123-12 Main St, Toronto, ON M5V 2T6",
    "Apt. 4 456 Yonge St, Toronto, ON M4Y 1X9",
    "Unit 201 789 Queen St W, Toronto, ON M6J 1G1",
    "Suite 300 1000 De La Gauchetière W, Montreal, QC H3B 4W5",
    "#5 100 Wellington St, Ottawa, ON K1A 0A9",
    "99999 Nowhere Blvd, Apt 12, Toronto, ON M5V 3A8"
  ]
}
