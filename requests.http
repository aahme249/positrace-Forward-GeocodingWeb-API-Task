@baseUrl = http://localhost:8080

### Mixed batch — all strategies in one request (address, postal_code, not_found, dedup)
POST {{baseUrl}}/api/v1/geocode
Content-Type: application/json

{
  "addresses": [
    "123-12 Main St, Toronto, ON M5V 2T6",
    "Apt. 4 456 Yonge St, Toronto, ON M4Y 1X9",
    "Unit 201 789 Queen St W, Toronto, ON M6J 1G1",
    "Suite 300 1000 De La Gauchetière W, Montreal, QC H3B 4W5",
    "#5 100 Wellington St, Ottawa, ON K1A 0A9",
    "Room 412 Fairmont Royal York, 100 Front St W, Toronto, ON M5J 1E3",
    "99999 Nowhere Blvd, Apt 12, Toronto, ON M5V 3A8",
    "Unit 5 99999 Nowhere Blvd, Faketown, ON",
    "CN Tower, 290 Bremner Blvd, Toronto, ON M5V 3L9",
    "Union Station, 65 Front St W, Toronto, ON M5J 1E6",
    "1 Hospital Rd, Iqaluit, NU X0A 0H0",
    "Apt 3 2568 Granville St, Vancouver, BC V6H 3G8",
    "100 Queen St W, Toronto, ON M5H 2N2",
    "100 Queen St W, Toronto, ON M5H 2N2"
  ]
}

###

### Dash-prefixed unit — 123-12 becomes 123
POST {{baseUrl}}/api/v1/geocode
Content-Type: application/json

{
  "addresses": [
    "123-12 Main St, Toronto, ON M5V 2T6"
  ]
}

###

### Apt / Apt. qualifier
POST {{baseUrl}}/api/v1/geocode
Content-Type: application/json

{
  "addresses": [
    "Apt 4 456 Yonge St, Toronto, ON M4Y 1X9",
    "Apt. 12B 789 Bloor St W, Toronto, ON M6G 1L5"
  ]
}

###

### Unit qualifier
POST {{baseUrl}}/api/v1/geocode
Content-Type: application/json

{
  "addresses": [
    "Unit 201 789 Queen St W, Toronto, ON M6J 1G1"
  ]
}

