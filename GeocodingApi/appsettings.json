{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.HttpLogging": "Information",
      "GeocodingApi": "Debug"
    },
    "Console": {
      "SingleLine": true
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=geocoding.db"
  },
  "Nominatim": {
    "BaseUrl": "https://nominatim.openstreetmap.org/",
    "UserAgent": "Positrace-Geocoding-Service/1.0 (asifahmed3959@gmail.com)",
    "RateLimitPerSecond": 1,
    "TimeoutSeconds": 5,
    "RetryCount": 3,
    "RetryDelaySeconds": 2,
    "CircuitBreakerFailures": 5,
    "CircuitBreakerBreakSeconds": 30
  }
}
